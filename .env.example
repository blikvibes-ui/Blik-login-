# Copy to .env and fill in real values. .env is gitignored.
#
# From Supabase: Project Settings → API (or the "Connect" button → Framework tab)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# The anon/publishable key is safe to ship in the built frontend bundle —
# every table it can reach is protected by Row Level Security
# (see supabase/migrations/0001_init.sql). It is NOT a secret the way a
# database password or service_role key is; never put a service_role key
# in a VITE_ variable, since anything prefixed VITE_ ends up in client-side
# JS that anyone can read.
